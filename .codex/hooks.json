{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|shell|shell_command|exec_command|command_execution",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/smart-hooks-runner.js\" PreToolUse",
            "commandWindows": "node C:/andrena/agentic-kanban/.claude/hooks/smart-hooks-runner.js PreToolUse",
            "timeout": 10,
            "statusMessage": "Checking command safety"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|apply_patch|apply_patch_freeform|functions.apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/prevent-cross-worktree-writes.js\"",
            "commandWindows": "node C:/andrena/agentic-kanban/.claude/hooks/prevent-cross-worktree-writes.js",
            "timeout": 10,
            "statusMessage": "Checking worktree write scope"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.claude/hooks/check-uncommitted.js\"",
            "commandWindows": "node C:/andrena/agentic-kanban/.claude/hooks/check-uncommitted.js",
            "timeout": 10,
            "statusMessage": "Checking for stranded uncommitted source changes"
          }
        ]
      }
    ]
  }
}
