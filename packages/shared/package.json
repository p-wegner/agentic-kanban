{
  "name": "@agentic-kanban/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./src/index.ts" },
    "./schema": { "types": "./dist/schema/index.d.ts", "import": "./dist/schema/index.js", "default": "./src/schema/index.ts" },
    "./types": { "types": "./dist/types/index.d.ts", "import": "./dist/types/index.js", "default": "./src/types/index.ts" },
    "./lib": { "types": "./dist/lib/index.d.ts", "import": "./dist/lib/index.js", "default": "./src/lib/index.ts" }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.3"
  }
}
