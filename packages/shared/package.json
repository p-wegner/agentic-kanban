{
  "name": "@agentic-kanban/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./src/index.ts" },
    "./schema": { "types": "./dist/schema/index.d.ts", "import": "./dist/schema/index.js", "default": "./src/schema/index.ts" },
    "./types": { "types": "./dist/types/index.d.ts", "import": "./dist/types/index.js", "default": "./src/types/index.ts" },
    "./lib": { "types": "./dist/lib/index.d.ts", "import": "./dist/lib/index.js", "default": "./src/lib/index.ts" },
    "./lib/agent-skill-files": { "types": "./dist/lib/agent-skill-files.d.ts", "import": "./dist/lib/agent-skill-files.js", "default": "./src/lib/agent-skill-files.ts" },
    "./lib/git-service": { "types": "./dist/lib/git-service.d.ts", "import": "./dist/lib/git-service.js", "default": "./src/lib/git-service.ts" },
    "./lib/setup-script": { "types": "./dist/lib/setup-script.d.ts", "import": "./dist/lib/setup-script.js", "default": "./src/lib/setup-script.ts" },
    "./lib/ticket-context": { "types": "./dist/lib/ticket-context.d.ts", "import": "./dist/lib/ticket-context.js", "default": "./src/lib/ticket-context.ts" },
    "./lib/cron-utils": { "types": "./dist/lib/cron-utils.d.ts", "import": "./dist/lib/cron-utils.js", "default": "./src/lib/cron-utils.ts" }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.3"
  }
}
