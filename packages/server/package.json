{
  "name": "agentic-kanban",
  "version": "0.1.7",
  "type": "module",
  "description": "Kanban board for AI-driven coding tasks — each card is a Claude Code session with built-in diff review and merge. Local-first, MCP-enabled, zero config.",
  "license": "MIT",
  "homepage": "https://github.com/p-wegner/agentic-kanban#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p-wegner/agentic-kanban.git"
  },
  "bugs": {
    "url": "https://github.com/p-wegner/agentic-kanban/issues"
  },
  "bin": {
    "agentic-kanban": "bin/cli.js",
    "agentic-kanban-mcp": "bin/mcp.js"
  },
  "files": [
    "bin/",
    "dist/cli/",
    "dist/server.js",
    "dist/mcp.js",
    "dist/client/",
    "dist/migrations/"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/cli.js dev",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/scripts/db-reset.ts && drizzle-kit migrate && tsx src/db/seed.ts",
    "db:repair": "tsx src/scripts/db-repair.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.3.1",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@agentic-kanban/shared": "workspace:*",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.0"
  }
}
