shamefully-hoist=false
strict-peer-dependencies=false
reporter=silent
# Silence npm's "Unknown env config" warnings emitted when npm/npx run as a child of
# pnpm (pnpm exports its config as npm_config_* env vars; npm rejects the pnpm-only keys).
# That banner was the #1 PowerShell failure cluster (stderr noise flips PS 5.1 exit codes)
# and pure token noise on nearly every npm/npx call. pnpm is already silent via reporter=silent.
loglevel=error
only-built-dependencies[]=better-sqlite3
only-built-dependencies[]=esbuild
