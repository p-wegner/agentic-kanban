{
  "mcpServers": {
    "agentic-kanban": {
      "command": "pnpm",
      "args": ["--filter", "@agentic-kanban/mcp-server", "dev"],
      "cwd": "F:\\projects\\agentic_kanban"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/pre_tool_use/require-code-review-for-pr.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/smart-hooks-runner.js PostToolUse"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/post_tool_use/monitor-pr-pipeline.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/smart-hooks-runner.js Stop"
          }
        ]
      }
    ]
  }
}
