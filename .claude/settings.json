{
  "mcpServers": {
    "agentic-kanban": {
      "command": "pnpm",
      "args": ["--filter", "@agentic-kanban/mcp-server", "dev"],
      "cwd": "C:/andrena/agentic-kanban"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/smart-hooks-runner.js PreToolUse"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/prevent-cross-worktree-writes.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/smart-hooks-runner.js PostToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:/andrena/agentic-kanban/.claude/hooks/smart-hooks-runner.js Stop"
          }
        ]
      }
    ]
  }
}
