{
  "name": "agentic-kanban",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@swc/core"
    ]
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "pnpm --filter agentic-kanban dev",
    "dev:client": "pnpm --filter client dev",
    "build": "pnpm --filter shared build && node scripts/build-server.mjs && node scripts/build-mcp.mjs && pnpm --filter client build && node scripts/copy-assets.mjs",
    "test": "pnpm --filter agentic-kanban test",
    "test:e2e": "pnpm --filter e2e test",
    "cli": "pnpm --filter agentic-kanban exec tsx src/cli/index.ts",
    "sh": "node -e \"const {execFileSync}=require('child_process'),a=process.argv.slice(2).filter(x=>x!=='--');execFileSync(process.execPath,['./node_modules/tsx/dist/cli.mjs','src/cli/index.ts','session-history',...a],{cwd:'packages/server',stdio:'inherit'})\"",
    "db:generate": "pnpm --filter shared db:generate",
    "db:migrate": "pnpm --filter agentic-kanban db:migrate",
    "db:seed": "pnpm --filter agentic-kanban db:seed",
    "db:reset": "pnpm --filter agentic-kanban db:reset",
    "db:repair": "pnpm --filter agentic-kanban db:repair",
    "db:setup": "pnpm db:migrate && pnpm db:seed && pnpm cli -- register .",
    "dev:desktop": "concurrently \"pnpm --filter agentic-kanban dev\" \"pnpm --filter client dev\" \"pnpm --filter @agentic-kanban/desktop dev\"",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@rollup/rollup-win32-x64-msvc": "^4.60.4",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.12",
    "typescript": "^5.8.3"
  }
}
